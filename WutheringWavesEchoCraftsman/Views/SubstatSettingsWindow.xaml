<Window x:Class="WutheringWavesEchoCraftsman.Views.SubstatSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="부옵션 설정"
        Height="640"
        Width="760">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="옵티마이즈 이후 잠금/폐기 판정에 사용할 부옵션 조건을 설정합니다."
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />
            <TextBlock Text="잠금을 위한 최소 유효 부옵션 개수" />
            <TextBox x:Name="RequiredCountTextBox" Width="120" HorizontalAlignment="Left" Margin="0,2,0,8" />
            <TextBlock Text="최소 수치는 비워두면 해당 부옵션의 최저값을 사용합니다. 저장 시 허용 범위를 벗어난 값은 자동 보정됩니다."
                       TextWrapping="Wrap"
                       Foreground="DimGray" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="저장"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="Save_Click" />
            <Button Content="닫기"
                    MinWidth="90"
                    Click="Close_Click" />
        </StackPanel>

        <DataGrid x:Name="SubstatDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="사용" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                <DataGridTextColumn Header="부옵션" Binding="{Binding DisplayName}" IsReadOnly="True" Width="160" />
                <DataGridTextColumn Header="최소 수치" Binding="{Binding MinValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                <DataGridTextColumn Header="허용 범위" Binding="{Binding RangeText}" IsReadOnly="True" Width="140" />
                <DataGridTextColumn Header="키" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
