<Window x:Class="WutheringWavesEchoCraftsman.Views.CalibrationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        Background="Black"
        KeyDown="Window_KeyDown">
    <Grid>
        <Image x:Name="ScreenshotImage" Stretch="Fill" />
        <Canvas x:Name="SelectionCanvas" Background="#33000000"
                MouseLeftButtonDown="SelectionCanvas_MouseLeftButtonDown"
                MouseMove="SelectionCanvas_MouseMove"
                MouseLeftButtonUp="SelectionCanvas_MouseLeftButtonUp">
            <Border x:Name="SelectionBorder"
                    BorderBrush="DodgerBlue"
                    BorderThickness="2"
                    Background="#332A7FFF"
                    Visibility="Collapsed" />
        </Canvas>
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Padding="16,10"
                Background="#CC111111"
                CornerRadius="6">
            <TextBlock x:Name="InstructionTextBlock"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="1100" />
        </Border>
    </Grid>
</Window>
