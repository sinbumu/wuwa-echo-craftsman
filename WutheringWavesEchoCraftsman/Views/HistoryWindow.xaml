<Window x:Class="WutheringWavesEchoCraftsman.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="히스토리"
        Height="480"
        Width="760">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Top"
                Content="새로고침"
                HorizontalAlignment="Left"
                Padding="12,4"
                Margin="0,0,0,8"
                Click="Refresh_Click" />
        <DataGrid x:Name="HistoryDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="시간" Binding="{Binding CreatedAt}" Width="180" />
                <DataGridTextColumn Header="판정" Binding="{Binding Decision}" Width="90" />
                <DataGridTextColumn Header="유효 수" Binding="{Binding ValidCount}" Width="80" />
                <DataGridTextColumn Header="OCR 원문" Binding="{Binding RawOcrText}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
