<Application x:Class="WutheringWavesEchoCraftsman.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WutheringWavesEchoCraftsman"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F7FB" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E7EB" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4B5563" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
